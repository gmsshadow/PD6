<form class="pd6 sheet item trait" autocomplete="off">
  <header class="pd6-item-header">
    <img src="{{item.img}}" data-edit="img" width="48" height="48" />
    <h1><input name="name" type="text" value="{{item.name}}" placeholder="Trait Name" /></h1>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="effects">Effects</a>
  </nav>

  <section class="sheet-body">

    {{!-- DESCRIPTION TAB --}}
    <div class="tab" data-group="primary" data-tab="description">
      <div class="pd6-item-fields">
        <div class="pd6-field">
          <label>Source</label>
          <input type="text" name="system.source" value="{{system.source}}" placeholder="Class, Race, Special, etc." />
        </div>
      </div>
      <div class="pd6-editor-container">
        {{editor system.description target="system.description" button=true owner=owner editable=editable}}
      </div>
    </div>

    {{!-- EFFECTS TAB --}}
    <div class="tab" data-group="primary" data-tab="effects">

      {{!-- Passive vs Conditional --}}
      <div class="pd6-trait-mode">
        <div class="pd6-field">
          <label>
            <input type="checkbox" name="system.passive" {{#if system.passive}}checked{{/if}} />
            Passive (always active)
          </label>
        </div>
        {{#unless system.passive}}
        <div class="pd6-field pd6-condition-note-field">
          <label>Condition Reminder (shown in roll dialogs)</label>
          <input type="text" name="system.conditionNote" value="{{system.conditionNote}}" 
                 placeholder="e.g. Only when defending against ranged attacks" />
        </div>
        {{/unless}}
      </div>

      {{!-- Effect Slots --}}
      {{#each effectSlots}}
      <div class="pd6-effect-slot {{#if (eq type 'none')}}pd6-effect-inactive{{else}}pd6-effect-active{{/if}}">
        <h4 class="pd6-effect-slot-header">{{label}}</h4>

        <div class="pd6-item-fields">
          <div class="pd6-field">
            <label>Effect Type</label>
            <select name="{{fType}}">
              <option value="none" {{#if (eq type "none")}}selected{{/if}}>None</option>
              <option value="diceColor" {{#if (eq type "diceColor")}}selected{{/if}}>Dice Colour Override</option>
              <option value="bonusDice" {{#if (eq type "bonusDice")}}selected{{/if}}>Bonus / Penalty Dice</option>
              <option value="attributeMod" {{#if (eq type "attributeMod")}}selected{{/if}}>Attribute Modifier</option>
              <option value="skillMod" {{#if (eq type "skillMod")}}selected{{/if}}>Skill Rank Modifier</option>
              {{#if (eq num 1)}}
              <option value="criticalInjury" {{#if (eq type "criticalInjury")}}selected{{/if}}>Critical Injury (roll twice)</option>
              {{/if}}
            </select>
          </div>

          {{!-- Dice Colour Override --}}
          {{#if (eq type "diceColor")}}
          <div class="pd6-field">
            <label>Override Colour</label>
            <select name="{{fColor}}">
              <option value="red" {{#if (eq diceColorOverride "red")}}selected{{/if}}>Red (3+)</option>
              <option value="black" {{#if (eq diceColorOverride "black")}}selected{{/if}}>Black (2+)</option>
              <option value="white" {{#if (eq diceColorOverride "white")}}selected{{/if}}>White (4+)</option>
            </select>
          </div>
          {{/if}}

          {{!-- Modifier Value --}}
          {{#if (or (eq type "bonusDice") (or (eq type "attributeMod") (eq type "skillMod")))}}
          <div class="pd6-field">
            <label>Modifier Value</label>
            <input type="number" name="{{fMod}}" value="{{modifierValue}}" />
          </div>
          {{/if}}

          {{!-- Target Skills --}}
          {{#if (or (eq type "diceColor") (or (eq type "bonusDice") (eq type "skillMod")))}}
          <div class="pd6-field pd6-full-width">
            <label>Target Skills (comma-separated, or "all")</label>
            <input type="text" name="{{fSkills}}" value="{{targetSkills}}" 
                   placeholder="e.g. discipline, leadership" />
          </div>
          {{/if}}

          {{!-- Target Attributes --}}
          {{#if (eq type "attributeMod")}}
          <div class="pd6-field pd6-full-width">
            <label>Target Attributes (comma-separated — also accepts "grit" and "luck")</label>
            <input type="text" name="{{fAttrs}}" value="{{targetAttributes}}" 
                   placeholder="e.g. might, toughness, grit, luck" />
          </div>
          {{/if}}
        </div>
      </div>
      {{/each}}

    </div>
  </section>
</form>
