<form class="pd6 sheet item weapon" autocomplete="off">
  <header class="pd6-item-header">
    <img src="{{item.img}}" data-edit="img" width="48" height="48" />
    <h1><input name="name" type="text" value="{{item.name}}" placeholder="Weapon Name" /></h1>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="details">Details</a>
    <a class="item" data-tab="traits">Traits</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="description">
      <div class="pd6-editor-container">
        {{editor system.description target="system.description" button=true owner=owner editable=editable}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="details">
      <div class="pd6-item-fields">
        <div class="pd6-field">
          <label>Type</label>
          <select name="system.weaponType">
            {{#each weaponTypes}}
              <option value="{{@key}}" {{#if (eq @key ../system.weaponType)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </div>
        <div class="pd6-field">
          <label>Damage</label>
          <input type="text" name="system.damage" value="{{system.damage}}" placeholder="M+0 or 3" />
        </div>
        <div class="pd6-field">
          <label>Armour Penetration</label>
          <input type="number" name="system.armorPenetration" value="{{system.armorPenetration}}" />
        </div>
        <div class="pd6-field">
          <label>Range/Reach</label>
          <input type="text" name="system.rangeReach" value="{{system.rangeReach}}" placeholder="5 ft" />
        </div>
        <div class="pd6-field">
          <label>Long Range</label>
          <input type="text" name="system.rangeLong" value="{{system.rangeLong}}" placeholder="—" />
        </div>
        <div class="pd6-field">
          <label>Dice Colour</label>
          <select name="system.diceColor">
            {{#each diceColors}}
              <option value="{{@key}}" {{#if (eq @key ../system.diceColor)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </div>
        <div class="pd6-field">
          <label>Cost</label>
          <input type="text" name="system.cost" value="{{system.cost}}" />
        </div>
        <div class="pd6-field">
          <label>Encumbrance</label>
          <input type="number" name="system.encumbrance" value="{{system.encumbrance}}" min="0" />
        </div>
        <div class="pd6-field">
          <label>Rarity</label>
          <input type="number" name="system.rarity" value="{{system.rarity}}" min="0" />
        </div>
        <div class="pd6-field">
          <label>Equipped</label>
          <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} />
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="traits">
      <div class="pd6-weapon-traits-grid">
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitBlock" {{#if system.traitBlock}}checked{{/if}} />
          <span class="pd6-trait-name">Block</span>
          <span class="pd6-trait-effect">Red defense dice while wielding</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitBrutal" {{#if system.traitBrutal}}checked{{/if}} />
          <span class="pd6-trait-name">Brutal</span>
          <span class="pd6-trait-effect">Damage dice → Red (3+)</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitCouched" {{#if system.traitCouched}}checked{{/if}} />
          <span class="pd6-trait-name">Couched</span>
          <span class="pd6-trait-effect">Mounted charge only; lost after hit</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitFast" {{#if system.traitFast}}checked{{/if}} />
          <span class="pd6-trait-name">Fast</span>
          <span class="pd6-trait-effect">+1 bonus to attack rolls</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitFlaming" {{#if system.traitFlaming}}checked{{/if}} />
          <span class="pd6-trait-name">Flaming</span>
          <span class="pd6-trait-effect">Deals flaming damage</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitNimble" {{#if system.traitNimble}}checked{{/if}} />
          <span class="pd6-trait-name">Nimble</span>
          <span class="pd6-trait-effect">Use Agility for Fighting instead of Might</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitParry" {{#if system.traitParry}}checked{{/if}} />
          <span class="pd6-trait-name">Parry</span>
          <span class="pd6-trait-effect">Red defense dice vs melee attacks</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitRepel" {{#if system.traitRepel}}checked{{/if}} />
          <span class="pd6-trait-name">Repel</span>
          <span class="pd6-trait-effect">No charge bonus for enemies</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitStunning" {{#if system.traitStunning}}checked{{/if}} />
          <span class="pd6-trait-name">Stunning</span>
          <span class="pd6-trait-effect">No penalty for subdual damage</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitSweep" {{#if system.traitSweep}}checked{{/if}} />
          <span class="pd6-trait-name">Sweep</span>
          <span class="pd6-trait-effect">Two attacks vs separate targets</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitTwoHanded" {{#if system.traitTwoHanded}}checked{{/if}} />
          <span class="pd6-trait-name">Two-Handed</span>
          <span class="pd6-trait-effect">Requires both hands to attack</span>
        </label>
        <label class="pd6-weapon-trait-checkbox">
          <input type="checkbox" name="system.traitWindlass" {{#if system.traitWindlass}}checked{{/if}} />
          <span class="pd6-trait-name">Windlass</span>
          <span class="pd6-trait-effect">Requires Reload action</span>
        </label>
      </div>
      <div class="pd6-field pd6-custom-traits">
        <label>Custom / Other Traits</label>
        <input type="text" name="system.traits" value="{{system.traits}}" placeholder="Additional traits not listed above" />
      </div>
    </div>
  </section>
</form>
